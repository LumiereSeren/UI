                optBtn.Name = opt
                optBtn.Parent = dropdownContainer
                optBtn.BackgroundColor3 = window.Theme.Secondary
                optBtn.BackgroundTransparency = 0.5
                optBtn.BorderSizePixel = 0
                optBtn.Size = dn(1, -10, 0, 25)
                optBtn.AutoButtonColor = false
                optBtn.Font = window.Theme.Font
                optBtn.Text = opt
                optBtn.TextColor3 = window.Theme.Text
                optBtn.TextSize = 13
                optBtn.ZIndex = 6

                local optCorner = Instance.new("UICorner")
                optCorner.CornerRadius = UDim.new(0, 4)
                optCorner.Parent = optBtn

                optBtn.MouseEnter:Connect(function()
                    TweenService:Create(optBtn, TweenInfo.new(0.1), {BackgroundTransparency = 0}):Play()
                end)
                optBtn.MouseLeave:Connect(function()
                    TweenService:Create(optBtn, TweenInfo.new(0.1), {BackgroundTransparency = 0.5}):Play()
                end)

                optBtn.MouseButton1Click:Connect(function()
                    selected = opt
                    valueLabel.Text = selected
                    dropdownContainer.Visible = false
                    open = false
                    arrow.Text = "▼"
                    if callback then callback(selected) end
                end)
            end

            frame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    open = not open
                    dropdownContainer.Visible = open
                    arrow.Text = open and "▲" or "▼"
                    if open then
                        dropdownContainer.Position = dn(0, 10, 0, frame.AbsoluteSize.Y + 2)
                    end
                end
            end)

            return {SetOptions = function(newOpts) end, GetSelected = function() return selected end}
        end

        function section:AddTextbox(text, default, callback)
            local frame = createBaseElement(section.Container, 30)

            local label = Instance.new("TextLabel")
            label.Parent = frame
            label.BackgroundTransparency = 1
            label.Size = dn(0, 80, 1, 0)
            label.Position = dn(0, 10, 0, 0)
            label.Font = window.Theme.Font
            label.Text = text
            label.TextColor3 = window.Theme.Text
            label.TextSize = 14
            label.TextXAlignment = Enum.TextXAlignment.Left

            local box = Instance.new("TextBox")
            box.Parent = frame
            box.BackgroundColor3 = window.Theme.Background
            box.BackgroundTransparency = 0.3
            box.BorderSizePixel = 0
            box.Size = dn(0, 150, 1, -10)
            box.Position = dn(1, -160, 0, 5)
            box.Font = window.Theme.Font
            box.Text = default or ""
            box.TextColor3 = window.Theme.Text
            box.PlaceholderText = "输入..."
            box.PlaceholderColor3 = window.Theme.Placeholder
            box.TextSize = 14
            box.ZIndex = 3

            local boxCorner = Instance.new("UICorner")
            boxCorner.CornerRadius = UDim.new(0, 4)
            boxCorner.Parent = box

            box.FocusLost:Connect(function()
                if callback then callback(box.Text) end
            end)

            return {GetText = function() return box.Text end, SetText = function(t) box.Text = t end}
        end

        function section:AddKeybind(text, default, callback)
            local frame = createBaseElement(section.Container, 30)
            local key = default or Enum.KeyCode.Unknown

            local label = Instance.new("TextLabel")
            label.Parent = frame
            label.BackgroundTransparency = 1
            label.Size = dn(1, -100, 1, 0)
            label.Position = dn(0, 10, 0, 0)
            label.Font = window.Theme.Font
            label.Text = text
            label.TextColor3 = window.Theme.Text
            label.TextSize = 14
            label.TextXAlignment = Enum.TextXAlignment.Left

            local keyBtn = Instance.new("TextButton")
            keyBtn.Parent = frame
            keyBtn.BackgroundColor3 = window.Theme.Background
            keyBtn.BackgroundTransparency = 0.3
            keyBtn.BorderSizePixel = 0
            keyBtn.Size = dn(0, 80, 0, 20)
            keyBtn.Position = dn(1, -90, 0.5, -10)
            keyBtn.Font = window.Theme.Font
            keyBtn.Text = key.Name or "None"
            keyBtn.TextColor3 = window.Theme.Accent
            keyBtn.TextSize = 13
            keyBtn.ZIndex = 3

            local keyCorner = Instance.new("UICorner")
            keyCorner.CornerRadius = UDim.new(0, 4)
            keyCorner.Parent = keyBtn

            local listening = false
            keyBtn.MouseButton1Click:Connect(function()
                listening = true
                keyBtn.Text = "..."
            end)

            UserInputService.InputBegan:Connect(function(input, processed)
                if listening and not processed then
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        key = input.KeyCode
                        keyBtn.Text = key.Name
                        listening = false
                        if callback then callback(key) end
                    end
                end
            end)

            return {GetKey = function() return key end}
        end

        return section
    end

    return window
end

-- 全局HttpGet辅助函数 (用于接入外部API)
function NovaUI:HttpGet(url, callback)
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    if callback then
        callback(success, result)
    end
    return result
end

-- 主题设置函数
function NovaUI:SetTheme(theme)
    self.Theme = deepCopy(theme)
end

return NovaUI
