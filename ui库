-- 拖拽功能
local function makeDraggable(frame, dragArea)
    dragArea = dragArea or frame
    local dragging, startPos, startMousePos
    dragArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            startPos = frame.Position
            startMousePos = input.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    dragArea.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - startMousePos
            if dragging then
                frame.Position = dn(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end
    end)
end

-- 创建一个窗口
function NovaUI:CreateWindow(config)
    config = config or {}
    local window = {}
    window.Title = config.Title or "NovaUI"
    window.Size = config.Size or dn(0, 600, 0, 400)
    window.Position = config.Position or dn(0.5, -300, 0.5, -200)
    window.Theme = config.Theme and deepCopy(config.Theme) or deepCopy(NovaUI.Theme)
    window.BackgroundImage = config.BackgroundImage
    window.AllowClose = config.AllowClose == nil and true or config.AllowClose
    window.AllowMinimize = config.AllowMinimize == nil and true or config.AllowMinimize
    window.OnClose = config.OnClose or function() end
    window.OnMinimize = config.OnMinimize or function() end
    window.OnRestore = config.OnRestore or function() end
    window.Icon = config.Icon  -- 可选图标ID

    -- 创建GUI容器
    window.Gui = Instance.new("ScreenGui")
    window.Gui.Name = "NovaUI_" .. HttpService:GenerateGUID(false)
    window.Gui.Parent = CoreGui
    window.Gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    if syn and syn.protect_gui then syn.protect_gui(window.Gui) end

    -- 主框架 (带阴影)
    window.Main = Instance.new("Frame")
    window.Main.Name = "Window"
    window.Main.Parent = window.Gui
    window.Main.BackgroundColor3 = window.Theme.Background
    window.Main.BackgroundTransparency = window.Theme.Transparency.Window
    window.Main.BorderSizePixel = 0
    window.Main.Position = window.Position
    window.Main.Size = window.Size
    window.Main.ClipsDescendants = true

    -- 圆角
    local mainCorner = Instance.new("UICorner")
    mainCorner.CornerRadius = window.Theme.CornerRadius
    mainCorner.Parent = window.Main

    -- 阴影效果 (使用多个半透明边框或使用ImageLabel)
    local shadow = Instance.new("ImageLabel")
    shadow.Name = "Shadow"
    shadow.Parent = window.Main
    shadow.BackgroundTransparency = 1
    shadow.Size = dn(1, window.Theme.ShadowSize*2, 1, window.Theme.ShadowSize*2)
    shadow.Position = dn(0, -window.Theme.ShadowSize, 0, -window.Theme.ShadowSize)
    shadow.Image = "rbxassetid://13161078036" -- 阴影图片
    shadow.ImageColor3 = window.Theme.Shadow
    shadow.ImageTransparency = 0.5
    shadow.ZIndex = -1

    -- 背景图片 (如果提供)
    if window.BackgroundImage then
        local bg = Instance.new("ImageLabel")
        bg.Name = "Background"
        bg.Parent = window.Main
        bg.BackgroundTransparency = 1
        bg.Size = dn(1,0,1,0)
        bg.Image = window.BackgroundImage
        bg.ScaleType = Enum.ScaleType.Crop
        bg.ZIndex = 0
    end

    -- 标题栏 (用于拖拽)
    window.TitleBar = Instance.new("Frame")
    window.TitleBar.Name = "TitleBar"
    window.TitleBar.Parent = window.Main
    window.TitleBar.BackgroundColor3 = window.Theme.Secondary
    window.TitleBar.BackgroundTransparency = window.Theme.Transparency.Element
    window.TitleBar.BorderSizePixel = 0
    window.TitleBar.Size = dn(1,0,0,30)
    window.TitleBar.ZIndex = 2

    local titleBarCorner = Instance.new("UICorner")
    titleBarCorner.CornerRadius = window.Theme.CornerRadius
    titleBarCorner.Parent = window.TitleBar

    -- 标题文字
    window.TitleLabel = Instance.new("TextLabel")
    window.TitleLabel.Parent = window.TitleBar
    window.TitleLabel.BackgroundTransparency = 1
    window.TitleLabel.Size = dn(1, -100, 1, 0)
    window.TitleLabel.Position = dn(0, 10, 0, 0)
    window.TitleLabel.Font = window.Theme.FontBold
    window.TitleLabel.Text = window.Title
    window.TitleLabel.TextColor3 = window.Theme.Text
    window.TitleLabel.TextSize = 16
    window.TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

    -- 图标 (如果有)
    if window.Icon then
        local icon = Instance.new("ImageLabel")
        icon.Parent = window.TitleBar
        icon.BackgroundTransparency = 1
        icon.Size = dn(0,20,0,20)
        icon.Position = dn(0,10,0,5)
        icon.Image = window.Icon
    end

    -- 按钮容器 (右上角)
    local btnContainer = Instance.new("Frame")
    btnContainer.Parent = window.TitleBar
    btnContainer.BackgroundTransparency = 1
    btnContainer.Size = dn(0, 70, 1, 0)
    btnContainer.Position = dn(1, -80, 0, 0)

    -- 最小化按钮
    if window.AllowMinimize then
        local minimize = Instance.new("TextButton")
        minimize.Name = "Minimize"
        minimize.Parent = btnContainer
        minimize.BackgroundTransparency = 1
        minimize.Size = dn(0,30,1,0)
        minimize.Position = dn(0,0,0,0)
