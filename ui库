    tabLayout.Parent = window.TabButtons
    tabLayout.FillDirection = Enum.FillDirection.Horizontal
    tabLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabLayout.Padding = UDim.new(0, 5)

    tabLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        window.TabButtons.CanvasSize = dn(0, tabLayout.AbsoluteContentSize.X, 0, 0)
    end)

    -- 标签内容区域
    window.TabContent = Instance.new("Frame")
    window.TabContent.Parent = window.Content
    window.TabContent.BackgroundTransparency = 1
    window.TabContent.Size = dn(1, 0, 1, -40)
    window.TabContent.Position = dn(0, 0, 0, 35)

    -- 存储标签页
    window.Tabs = {}

    -- 当前标签
    window.CurrentTab = nil

    -- 最小化状态
    window.IsMinimized = false
    window.OriginalSize = window.Size

    -- 方法: 最小化
    function window:Minimize()
        if self.IsMinimized then
            -- 还原
            TweenService:Create(self.Main, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = self.OriginalSize}):Play()
            self.IsMinimized = false
            self.OnRestore()
        else
            -- 最小化到标题栏高度
            self.OriginalSize = self.Main.Size
            TweenService:Create(self.Main, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = dn(0, self.OriginalSize.X.Offset, 0, 30)}):Play()
            self.IsMinimized = true
            self.OnMinimize()
        end
    end

    -- 方法: 关闭
    function window:Close()
        self.Gui:Destroy()
        self.OnClose()
    end

    -- 方法: 创建标签页
    function window:CreateTab(name, icon)
        local tab = {}
        tab.Name = name
        tab.Icon = icon

        -- 创建标签按钮
        local btn = Instance.new("TextButton")
        btn.Name = "Tab_" .. name
        btn.Parent = window.TabButtons
        btn.BackgroundColor3 = window.Theme.Secondary
        btn.BackgroundTransparency = window.Theme.Transparency.Element
        btn.BorderSizePixel = 0
        btn.Size = dn(0, 100, 0, 28)
        btn.AutoButtonColor = false
        btn.Font = window.Theme.Font
        btn.Text = name
        btn.TextColor3 = window.Theme.Text
        btn.TextSize = 14
        btn.ZIndex = 3

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = window.Theme.SmallCorner
        btnCorner.Parent = btn

        -- 悬停效果
        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0}):Play()
        end)
        btn.MouseLeave:Connect(function()
            if window.CurrentTab ~= btn then
                TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = window.Theme.Transparency.Element}):Play()
            end
        end)

        -- 创建标签内容容器
        tab.Container = Instance.new("ScrollingFrame")
        tab.Container.Parent = window.TabContent
        tab.Container.BackgroundTransparency = 1
        tab.Container.BorderSizePixel = 0
        tab.Container.Size = dn(1,0,1,0)
        tab.Container.Visible = false
        tab.Container.CanvasSize = dn(0,0,0,0)
        tab.Container.ScrollBarThickness = 6

        local contentLayout = Instance.new("UIListLayout")
        contentLayout.Parent = tab.Container
        contentLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
        contentLayout.Padding = UDim.new(0, 10)

        contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            tab.Container.CanvasSize = dn(0,0,0, contentLayout.AbsoluteContentSize.Y + 10)
        end)

        local contentPadding = Instance.new("UIPadding")
        contentPadding.Parent = tab.Container
        contentPadding.PaddingTop = UDim.new(0, 5)

        -- 选中状态
        btn.MouseButton1Click:Connect(function()
            if window.CurrentTab then
                window.CurrentTab.Container.Visible = false
                TweenService:Create(window.CurrentTab.Button, TweenInfo.new(0.1), {BackgroundTransparency = window.Theme.Transparency.Element}):Play()
            end
            window.CurrentTab = tab
            tab.Container.Visible = true
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0}):Play()
        end)

        tab.Button = btn

        -- 如果这是第一个标签，自动选中
        if #window.Tabs == 0 then
            window.CurrentTab = tab
            tab.Container.Visible = true
            btn.BackgroundTransparency = 0
        end

        table.insert(window.Tabs, tab)

        -- 返回标签对象，用于添加控件
        return tab
    end

    -- 通用控件创建函数
    local function createBaseElement(parent, height, transparency)
        local frame = Instance.new("Frame")
        frame.Parent = parent
        frame.BackgroundColor3 = window.Theme.Secondary
        frame.BackgroundTransparency = transparency or window.Theme.Transparency.Element
        frame.BorderSizePixel = 0
        frame.Size = dn(1, -20, 0, height or 35)
        frame.ZIndex = 2

        local corner = Instance.new("UICorner")
        corner.CornerRadius = window.Theme.SmallCorner
        corner.Parent = frame

        return frame
    end

