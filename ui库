            local function updateVisual()
                if state then
                    TweenService:Create(toggleBg, TweenInfo.new(0.2), {BackgroundColor3 = window.Theme.Accent}):Play()
                    TweenService:Create(toggleCircle, TweenInfo.new(0.2), {Position = dn(0, 21, 0.5, -9)}):Play()
