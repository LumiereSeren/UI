-- 辅助函数
local function c3(r,g,b) return Color3.fromRGB(r,g,b) end
local function dm(scale, offset) return UDim.new(scale, offset) end
local function dn(xScale, xOffset, yScale, yOffset) return UDim2.new(xScale, xOffset, yScale, yOffset) end
local function deepCopy(t) local nt = {}; for k,v in pairs(t) do nt[k] = type(v)=="table" and deepCopy(v) or v end; return nt end

