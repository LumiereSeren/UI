            toggleBg.ZIndex = 3

            local toggleCorner = Instance.new("UICorner")
            toggleCorner.CornerRadius = UDim.new(0, 10)
            toggleCorner.Parent = toggleBg

            local toggleCircle = Instance.new("Frame")
            toggleCircle.Parent = toggleBg
